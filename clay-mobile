<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Clay — 3D Modeler</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230e0e0e'/><text x='3' y='26' font-size='26' font-family='Georgia,serif' font-weight='900' fill='%23c8ff00'>C</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0e0e0e;--panel:#161616;--panel2:#1c1c1c;--border:#2a2a2a;--accent:#c8ff00;--accent2:#ff6b35;--text:#e8e8e8;--muted:#666;--sel:#c8ff0022;--menu-h:50px;--bar-h:64px;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--text);font-family:'Space Mono',monospace;height:100dvh;display:flex;flex-direction:column;overflow:hidden;touch-action:none;}

/* ── HEADER ── */
.hdr{display:flex;align-items:center;padding:0 16px;border-bottom:1px solid var(--border);background:var(--panel);flex-shrink:0;height:var(--menu-h);gap:10px;z-index:50;}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--accent);cursor:pointer;}

/* ── MENU BAR ── */
.menubar{display:flex;align-items:stretch;height:var(--bar-h);background:var(--panel2);border-bottom:1px solid var(--border);flex-shrink:0;z-index:40;}
.mb-item{display:flex;flex:1;align-items:center;justify-content:center;flex-direction:column;gap:3px;padding:0 4px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:0.5px;text-transform:uppercase;color:var(--muted);cursor:pointer;border-right:1px solid var(--border);transition:all .15s;user-select:none;-webkit-user-select:none;position:relative;min-width:0;}
.mb-item:last-child{border-right:none;}
.mb-item .icon{font-size:20px;line-height:1;}
.mb-item .label{font-size:9px;letter-spacing:0.5px;white-space:nowrap;}
.mb-item:active{background:var(--sel);color:var(--accent);}
.mb-item.open{background:var(--sel);color:var(--accent);}

/* ── DROPDOWN MENUS ── */
.dropdown{position:fixed;top:calc(var(--menu-h) + var(--bar-h));background:var(--panel);border:1px solid var(--border);min-width:260px;z-index:500;display:none;flex-direction:column;box-shadow:0 16px 48px rgba(0,0,0,.9);}
.dropdown.open{display:flex;}
.dd-item{display:flex;align-items:center;gap:14px;padding:16px 18px;font-size:13px;letter-spacing:0.5px;text-transform:uppercase;cursor:pointer;border-bottom:1px solid #1e1e1e;transition:background .1s;user-select:none;min-height:54px;}
.dd-item:last-child{border-bottom:none;}
.dd-item:active,.dd-item:hover{background:var(--panel2);color:var(--accent);}
.dd-item .di{font-size:20px;width:28px;text-align:center;color:var(--muted);}
.dd-item.danger:hover,.dd-item.danger:active{color:#f44;}
.dd-item.disabled{opacity:.35;pointer-events:none;}
.dd-sep{height:1px;background:var(--border);margin:3px 0;}
.dd-label{font-size:10px;letter-spacing:2px;color:var(--muted);padding:12px 18px 6px;text-transform:uppercase;}
.dd-row{display:flex;align-items:center;gap:10px;padding:12px 18px;border-bottom:1px solid #1e1e1e;min-height:52px;}
.dd-row label{font-size:12px;color:var(--muted);flex:1;}
.dd-row input[type=range]{flex:1;accent-color:var(--accent);height:6px;}
.dd-row span{font-size:13px;color:var(--accent);min-width:36px;text-align:right;}
.dd-row input[type=color]{width:36px;height:30px;border:1px solid var(--border);background:none;cursor:pointer;padding:0;}
.dd-row input[type=checkbox]{accent-color:var(--accent);width:20px;height:20px;}
.dd-item .badge{margin-left:auto;font-size:10px;background:var(--accent);color:#000;padding:2px 7px;letter-spacing:0;}
.dd-item .act-dot{margin-left:auto;width:8px;height:8px;border-radius:50%;background:var(--accent);}
/* mesh mode select in dd-row */
.dd-row select{flex:1;font-family:'Space Mono',monospace;font-size:12px;background:var(--panel2);color:var(--text);border:1px solid var(--border);padding:6px 8px;cursor:pointer;}

/* ── VIEWPORT ── */
.vp{flex:1;position:relative;background:#080808;overflow:hidden;}
#c3{display:block;width:100%;height:100%;touch-action:none;}
.vhint{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);font-size:10px;letter-spacing:1.5px;color:#333;text-transform:uppercase;pointer-events:none;white-space:nowrap;}
.es{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;pointer-events:none;}
.es .big{font-family:'Syne',sans-serif;font-size:clamp(40px,18vw,80px);font-weight:800;color:#181818;letter-spacing:-4px;}
.es p{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;text-align:center;}
.pbar{position:absolute;bottom:0;left:0;right:0;height:4px;background:var(--border);display:none;}
.pfill{height:100%;background:var(--accent);width:0%;transition:width .1s;}
.sb{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.8);padding:6px 10px;font-size:11px;letter-spacing:0.5px;color:var(--muted);pointer-events:none;max-width:calc(100% - 24px);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sb.active{color:var(--accent);}
.sel-bar{position:absolute;bottom:12px;right:12px;background:rgba(0,0,0,.85);border:1px solid var(--border);padding:8px 12px;font-size:11px;color:var(--muted);display:none;gap:8px;align-items:center;}
.sel-bar.vis{display:flex;}
.sel-bar .sn{color:var(--accent);}

/* ── OVERLAY ── */
.overlay{position:fixed;inset:0;z-index:400;display:none;}
.overlay.open{display:block;}

/* ── MODALS ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:600;display:none;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal{background:var(--panel);border:1px solid var(--border);width:calc(100% - 24px);max-width:620px;max-height:90dvh;display:flex;flex-direction:column;}
.modal-hdr{display:flex;align-items:center;padding:14px 16px;border-bottom:1px solid var(--border);gap:10px;flex-shrink:0;}
.modal-hdr h2{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;flex:1;}
.modal-close{background:none;border:none;color:var(--muted);font-size:26px;cursor:pointer;padding:6px;line-height:1;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;}
.fnav{display:flex;gap:4px;flex-wrap:wrap;padding:10px 12px;border-bottom:1px solid var(--border);flex-shrink:0;}
.fnav button{padding:8px 14px;font-size:12px;font-family:'Space Mono',monospace;letter-spacing:0.5px;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;transition:all .15s;min-height:40px;}
.fnav button.act{border-color:var(--accent);color:var(--accent);background:var(--sel);}
.fnav button:active{border-color:var(--accent);color:var(--accent);}
.modal-body{display:flex;flex:1;overflow:hidden;min-height:0;}
.modal-tools{width:120px;padding:8px;border-right:1px solid var(--border);overflow-y:auto;flex-shrink:0;display:flex;flex-direction:column;gap:5px;}
.modal-tools::-webkit-scrollbar{display:none;}
.tgl{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:6px;}
.tg2{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.tg2 button{padding:9px 3px;font-size:10px;font-family:'Space Mono',monospace;letter-spacing:0;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;min-height:38px;}
.tg2 button.act{border-color:var(--accent);color:var(--accent);background:var(--sel);}
.fb2{width:100%;padding:9px;font-size:10px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;letter-spacing:0;min-height:38px;}
.fb2.act{border-color:var(--accent);color:var(--accent);background:var(--sel);}
.cr{display:flex;align-items:center;gap:6px;}
.cr label{font-size:10px;color:var(--muted);}
.cr input[type=color]{width:30px;height:24px;border:1px solid var(--border);background:none;cursor:pointer;padding:0;}
.szr{display:flex;align-items:center;gap:4px;}
.szr input[type=range]{flex:1;accent-color:var(--accent);}
.szr span{font-size:10px;color:var(--accent);min-width:18px;}
.canvas-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0a0a0a;position:relative;min-height:0;padding:8px;}
#pfc{cursor:crosshair;image-rendering:pixelated;display:block;touch-action:none;max-width:100%;max-height:100%;}
.cht{position:absolute;bottom:4px;left:0;right:0;text-align:center;font-size:9px;color:#333;letter-spacing:1px;pointer-events:none;}
.modal-ftr{display:flex;gap:8px;padding:10px 14px;border-top:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;}
.modal-ftr button{padding:10px 16px;font-size:12px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;min-height:44px;}
.modal-ftr button.primary{background:var(--accent);color:#000;border-color:var(--accent);font-weight:700;}
.modal-ftr .sp{flex:1;}

/* ── ABOUT ── */
.modal-about{max-width:420px;}
.ab-top{height:4px;background:linear-gradient(90deg,var(--accent),var(--accent2),var(--accent));flex-shrink:0;}
.ab-bot{height:4px;background:linear-gradient(90deg,var(--accent2),var(--accent),var(--accent2));flex-shrink:0;}
.ab-body{padding:28px 28px 24px;display:flex;flex-direction:column;align-items:center;gap:14px;overflow-y:auto;}
.ab-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:52px;color:var(--accent);letter-spacing:-2px;line-height:1;}
.ab-sub{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--muted);}
.ab-desc{font-size:13px;line-height:1.9;color:var(--text);text-align:center;}
.ab-desc strong{color:var(--accent);}
.ab-ver{font-size:10px;color:var(--muted);letter-spacing:2px;}
.ab-btns{display:flex;gap:10px;margin-top:4px;}
.ab-btns button{padding:12px 20px;font-size:13px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;min-height:48px;}
.ab-btns button.primary{background:var(--accent);color:#000;border-color:var(--accent);font-weight:700;}

/* ── TUTORIAL ── */
.modal-tut{max-height:88dvh;}
.tut-body{overflow-y:auto;padding:18px 20px;flex:1;}
.tut-body::-webkit-scrollbar{width:4px;} .tut-body::-webkit-scrollbar-thumb{background:var(--border);}
.tstep{display:flex;gap:14px;margin-bottom:18px;}
.tnum{width:30px;height:30px;border-radius:50%;background:var(--accent);color:#000;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.tstep-b h4{font-size:13px;color:var(--accent);margin-bottom:5px;}
.tstep-b p{font-size:12px;color:var(--muted);line-height:1.8;}
.tstep-b strong{color:var(--text);}
.ttip{background:var(--panel2);border:1px solid var(--border);border-left:3px solid var(--accent2);padding:12px 14px;margin-bottom:16px;font-size:12px;color:var(--muted);line-height:1.8;}
.ttip strong{color:var(--accent2);}

/* ── OBJECTS ── */
.modal-objs{max-height:70dvh;max-width:380px;}
.modal-objs .modal-body{flex-direction:column;overflow-y:auto;}
.oi{display:flex;align-items:center;gap:10px;padding:14px 16px;cursor:pointer;border-left:3px solid transparent;border-bottom:1px solid #1a1a1a;transition:all .1s;min-height:54px;}
.oi:active,.oi:hover{background:var(--panel2);}
.oi.sel{border-left-color:var(--accent);background:var(--sel);}
.odot{width:12px;height:12px;border-radius:50%;border:1px solid var(--border);flex-shrink:0;}
.oname{flex:1;font-size:14px;outline:none;background:transparent;color:var(--text);border:none;cursor:pointer;font-family:'Space Mono',monospace;min-width:0;pointer-events:none;}
.oi.sel .oname{pointer-events:auto;cursor:text;}
.obj-actions{display:flex;gap:6px;padding:12px 14px;border-top:1px solid var(--border);flex-shrink:0;}
.obj-actions button{flex:1;padding:12px 8px;font-size:12px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;min-height:48px;}
.obj-actions button:active{border-color:var(--accent);color:var(--accent);}
.obj-actions button.danger:active{border-color:#f44;color:#f44;}

/* ── FACES ── */
.modal-faces{max-height:80dvh;}
.fgrid-m{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:14px;}
.ftb{aspect-ratio:1;border:1px solid var(--border);background:#111;cursor:pointer;position:relative;overflow:hidden;display:flex;align-items:flex-end;justify-content:center;padding-bottom:4px;transition:border-color .15s;}
.ftb:active{border-color:var(--accent);}
.ftb.af{border-color:var(--accent2);box-shadow:0 0 0 1px var(--accent2);}
.ftb canvas{position:absolute;inset:0;width:100%;height:100%;image-rendering:pixelated;}
.ftb span{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);position:relative;z-index:1;background:rgba(0,0,0,.7);padding:2px 5px;}
.no-obj{padding:24px;text-align:center;font-size:13px;color:var(--muted);}

/* ── TRANSFORM (stepper) ── */
.modal-tf{max-width:380px;}
.tf-group{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;}
.tf-group h4{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);}
.tf-row{display:flex;align-items:center;gap:8px;height:52px;}
.tf-row label{font-size:14px;color:var(--muted);width:20px;flex-shrink:0;}
.tf-val{flex:1;font-size:16px;color:var(--text);font-family:'Space Mono',monospace;text-align:center;background:var(--panel2);border:1px solid var(--border);height:100%;display:flex;align-items:center;justify-content:center;}
.tf-btn-sm{width:52px;height:52px;font-size:24px;font-family:'Space Mono',monospace;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .1s;user-select:none;}
.tf-btn-sm:active{border-color:var(--accent);color:var(--accent);background:var(--sel);}
.tf-btn{padding:14px;font-size:13px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;width:100%;min-height:52px;}
.tf-btn.act{border-color:var(--accent);color:var(--accent);background:var(--sel);}

/* ── BUILD MODAL ── */
.modal-build{max-width:380px;}
.modal-build .modal-body{flex-direction:column;padding:14px 16px;gap:14px;overflow-y:auto;}
.brow{display:flex;align-items:center;gap:10px;min-height:48px;}
.brow label{font-size:13px;color:var(--muted);min-width:80px;}
.brow input[type=range]{flex:1;accent-color:var(--accent);height:6px;}
.brow span{font-size:14px;color:var(--accent);min-width:36px;text-align:right;}
.brow input[type=color]{width:36px;height:30px;border:1px solid var(--border);background:none;cursor:pointer;padding:0;}
.brow input[type=checkbox]{accent-color:var(--accent);width:20px;height:20px;}
.brow select{flex:1;font-family:'Space Mono',monospace;font-size:12px;background:var(--panel2);color:var(--text);border:1px solid var(--border);padding:8px;cursor:pointer;}
.build-btn{width:100%;padding:14px;font-size:13px;font-family:'Space Mono',monospace;text-transform:uppercase;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text);min-height:52px;margin-bottom:8px;}
.build-btn.primary{background:var(--accent);color:#000;border-color:var(--accent);font-weight:700;}
.build-hint{font-size:10px;color:var(--muted);line-height:1.6;}

/* ── IMPORT OBJ MODAL ── */
.modal-import{max-width:400px;}
.modal-import .modal-body{flex-direction:column;overflow-y:auto;padding:14px 16px;gap:12px;}
.imp-section label{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;display:block;margin-bottom:6px;}
.imp-list{list-style:none;}
.imp-item{padding:12px 14px;font-size:12px;border:1px solid var(--border);margin-bottom:6px;cursor:pointer;display:flex;align-items:center;gap:8px;min-height:48px;}
.imp-item:active{border-color:var(--accent);color:var(--accent);}
.imp-item.sel{border-color:var(--accent);background:var(--sel);}
.imp-stat{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.7;}

/* ── ANIMATOR MODAL ── */
.modal-anim{max-width:95vw;width:95vw;max-height:60dvh;}
.modal-anim .modal-body{flex-direction:column;overflow:hidden;}
.anim-toolbar{display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;}
.anim-toolbar button{padding:8px 14px;font-size:11px;font-family:'Space Mono',monospace;text-transform:uppercase;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;min-height:40px;}
.anim-toolbar button.primary{background:var(--accent);color:#000;border-color:var(--accent);}
.anim-toolbar button.act{border-color:var(--accent);color:var(--accent);background:var(--sel);}
.anim-counter{font-size:13px;color:var(--accent);padding:0 6px;}
.anim-body{display:flex;flex:1;overflow:hidden;}
.anim-obj-col{width:120px;flex-shrink:0;border-right:1px solid var(--border);overflow-y:auto;background:#0e0e0e;}
.anim-obj-row{height:32px;display:flex;align-items:center;padding:0 10px;font-size:10px;border-bottom:1px solid var(--border);white-space:nowrap;overflow:hidden;color:var(--muted);}
.anim-obj-row.hdr{color:var(--accent);font-size:9px;letter-spacing:2px;}
.anim-timeline{flex:1;overflow-x:auto;overflow-y:auto;position:relative;background:#0a0a0a;cursor:crosshair;}
.anim-ruler{height:32px;background:#111;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:10;display:flex;align-items:flex-end;position:relative;}
.anim-ruler-tick{position:absolute;bottom:0;font-size:8px;color:var(--muted);padding-bottom:3px;user-select:none;}
.anim-track-row{height:32px;border-bottom:1px solid var(--border);position:relative;}
.anim-keyframe{position:absolute;top:50%;transform:translate(-50%,-50%) rotate(45deg);width:12px;height:12px;background:var(--accent);cursor:pointer;border:1px solid #000;}
.anim-keyframe:active{background:var(--accent2);}
.anim-keyframe.sel{background:var(--accent2);box-shadow:0 0 0 2px white;}
.anim-playhead{position:absolute;top:0;bottom:0;width:2px;background:var(--accent2);z-index:20;pointer-events:none;}
.anim-playhead-head{position:absolute;top:0;left:-5px;width:12px;height:12px;background:var(--accent2);clip-path:polygon(50% 100%,0 0,100% 0);}
</style>
</head>
<body>

<!-- HEADER -->
<div class="hdr">
  <div class="logo" id="logoBtn">Clay</div>
  <div style="font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-left:auto">v3.5 Mobile</div>
</div>

<!-- MENU BAR -->
<div class="menubar">
  <div class="mb-item" id="mbFile" data-menu="menuFile"><span class="icon">📁</span><span class="label">File</span></div>
  <div class="mb-item" id="mbEdit" data-menu="menuEdit"><span class="icon">✏️</span><span class="label">Edit</span></div>
  <div class="mb-item" id="mbView" data-menu="menuView"><span class="icon">👁️</span><span class="label">View</span></div>
  <div class="mb-item" id="mbBuild" data-menu="menuBuild"><span class="icon">⚙️</span><span class="label">Build</span></div>
  <div class="mb-item" id="mbFaces" data-menu="menuFaces"><span class="icon">🎨</span><span class="label">Faces</span></div>
</div>

<!-- OVERLAY -->
<div class="overlay" id="overlay"></div>

<!-- FILE MENU -->
<div class="dropdown" id="menuFile">
  <div class="dd-item" id="ddSave"><span class="di">💾</span> Save .cly</div>
  <div class="dd-item" id="ddLoad"><span class="di">📂</span> Load .cly</div>
  <input type="file" id="loadInput" accept=".cly" style="display:none">
  <div class="dd-sep"></div>
  <div class="dd-item" id="ddImportObj"><span class="di">⬆️</span> Import OBJ</div>
  <input type="file" id="importObjFile" accept=".obj" style="display:none">
  <div class="dd-item" id="ddExportObj"><span class="di">📤</span> Export OBJ</div>
  <div class="dd-sep"></div>
  <div class="dd-item" id="ddAbout"><span class="di">ℹ️</span> About</div>
  <div class="dd-item" id="ddTutorial"><span class="di">📖</span> Tutorial</div>
</div>

<!-- EDIT MENU -->
<div class="dropdown" id="menuEdit">
