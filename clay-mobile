  let out='# Clay 3D Modeler v3.5 Mobile Export\n\n';let off=0;
  objects.forEach(o=>{if(!o.exp)return;const{pos,nor,col,ind}=o.exp;out+=`o ${o.name}\n`;
  for(let i=0;i<pos.length;i+=3)out+=`v ${pos[i].toFixed(4)} ${pos[i+1].toFixed(4)} ${pos[i+2].toFixed(4)} ${(col[i]||0).toFixed(3)} ${(col[i+1]||0).toFixed(3)} ${(col[i+2]||0).toFixed(3)}\n`;
  for(let i=0;i<nor.length;i+=3)out+=`vn ${nor[i].toFixed(4)} ${nor[i+1].toFixed(4)} ${nor[i+2].toFixed(4)}\n`;
  for(let i=0;i<ind.length;i+=3){const a=ind[i]+1+off,b=ind[i+1]+1+off,c=ind[i+2]+1+off;out+=`f ${a}//${a} ${b}//${b} ${c}//${c}\n`;}off+=pos.length/3;out+='\n';});
  const bl=new Blob([out],{type:'text/plain'});const a=document.createElement('a');a.href=URL.createObjectURL(bl);a.download='clay_scene.obj';a.click();
});

// ── IMPORT OBJ ────────────────────────────────────────
let importedObjs=[],importSelIdx=0;
function parseOBJ(text){const lines=text.split('\n');const verts=[],objects2=[];let cur=null;function nObj(name){cur={name:name||('Object'+(objects2.length+1)),faces:[],hasColor:false};objects2.push(cur);}nObj('Object1');for(const line of lines){const parts=line.trim().split(/\s+/),cmd=parts[0];if(cmd==='v')verts.push([parseFloat(parts[1])||0,parseFloat(parts[2])||0,parseFloat(parts[3])||0,parts[4]!==undefined?parseFloat(parts[4]):1,parts[5]!==undefined?parseFloat(parts[5]):1,parts[6]!==undefined?parseFloat(parts[6]):1]);else if(cmd==='o'||cmd==='g'){if(cur&&cur.faces.length===0&&objects2.length>1)cur.name=parts.slice(1).join(' ')||cur.name;else nObj(parts.slice(1).join(' '));}else if(cmd==='f'){const idx=parts.slice(1).map(p=>parseInt(p.split('/')[0])-1);for(let i=1;i<idx.length-1;i++)cur.faces.push([idx[0],idx[i],idx[i+1]]);}}return objects2.filter(o=>o.faces.length>0).map(o=>{const used=new Set(o.faces.flat());const usedA=[...used];const rem=new Map(usedA.map((vi,ni)=>[vi,ni]));return{name:o.name,verts:usedA.map(vi=>[verts[vi]?.[0]||0,verts[vi]?.[1]||0,verts[vi]?.[2]||0]),colors:usedA.map(vi=>[verts[vi]?.[3]??1,verts[vi]?.[4]??1,verts[vi]?.[5]??1]),faces:o.faces.map(f=>f.map(vi=>rem.get(vi)))};});}
function normalizeOBJ(obj){let minX=Infinity,minY=Infinity,minZ=Infinity,maxX=-Infinity,maxY=-Infinity,maxZ=-Infinity;for(const[x,y,z]of obj.verts){minX=Math.min(minX,x);minY=Math.min(minY,y);minZ=Math.min(minZ,z);maxX=Math.max(maxX,x);maxY=Math.max(maxY,y);maxZ=Math.max(maxZ,z);}const cx=(minX+maxX)/2,cy=(minY+maxY)/2,cz=(minZ+maxZ)/2,scale=2/Math.max(maxX-minX,maxY-minY,maxZ-minZ,0.001);return{...obj,verts:obj.verts.map(([x,y,z])=>[(x-cx)*scale,(y-cy)*scale,(z-cz)*scale])};}
function buildImportedMesh(objData){const useSolid=document.getElementById('importSolidCheck').checked;const solidHex=document.getElementById('importSolidColor').value;let pos=[],nor=[],col=[],ind=[];for(const[i,j,k]of objData.faces){const vA=objData.verts[i],vB=objData.verts[j],vC=objData.verts[k];if(!vA||!vB||!vC)continue;const cA=objData.colors[i]||[1,1,1],cB=objData.colors[j]||[1,1,1],cC=objData.colors[k]||[1,1,1];const ax=vB[0]-vA[0],ay=vB[1]-vA[1],az=vB[2]-vA[2],bx=vC[0]-vA[0],by=vC[1]-vA[1],bz=vC[2]-vA[2];let nx=ay*bz-az*by,ny=az*bx-ax*bz,nz=ax*by-ay*bx;const nl=Math.sqrt(nx*nx+ny*ny+nz*nz)||1;nx/=nl;ny/=nl;nz/=nl;const base=pos.length/3;for(const[v,c]of[[vA,cA],[vB,cB],[vC,cC]]){pos.push(v[0],v[1],v[2]);nor.push(nx,ny,nz);col.push(c[0],c[1],c[2]);}ind.push(base,base+1,base+2);}if(useSolid){const r2=parseInt(solidHex.slice(1,3),16)/255,g2=parseInt(solidHex.slice(3,5),16)/255,b2=parseInt(solidHex.slice(5,7),16)/255;for(let i=0;i<col.length;i+=3){col[i]=r2;col[i+1]=g2;col[i+2]=b2;}}const geo=new THREE.BufferGeometry();geo.setAttribute('position',new THREE.Float32BufferAttribute(pos,3));geo.setAttribute('normal',new THREE.Float32BufferAttribute(nor,3));geo.setAttribute('color',new THREE.Float32BufferAttribute(col,3));geo.setIndex(ind);geo.computeBoundingSphere();return{pos,nor,col,ind,geo};}
function handleImportFile(file){if(!file)return;const reader=new FileReader();reader.onload=e=>{try{importedObjs=parseOBJ(e.target.result).map(normalizeOBJ);importSelIdx=0;document.getElementById('importStat').textContent=`Loaded: ${file.name} — ${importedObjs.length} object(s)`;buildImpList();document.getElementById('importMeshSection').style.display='block';document.getElementById('importBuildSection').style.display='block';}catch(err){document.getElementById('importStat').textContent='Error: '+err.message;}};reader.readAsText(file);}
function buildImpList(){const ul=document.getElementById('importObjList');ul.innerHTML='';importedObjs.forEach((o,i)=>{const li=document.createElement('li');li.className='imp-item'+(i===importSelIdx?' sel':'');li.textContent=`${o.name} (${o.faces.length} tris)`;li.addEventListener('click',()=>{importSelIdx=i;buildImpList();});ul.appendChild(li);});}
document.getElementById('ddImportObj').addEventListener('click',()=>openModal('povImport'));
document.getElementById('importClose').addEventListener('click',()=>document.getElementById('povImport').classList.remove('open'));
document.getElementById('importChooseBtn').addEventListener('click',()=>document.getElementById('importObjFile2').click());
document.getElementById('importObjFile2').addEventListener('change',e=>{handleImportFile(e.target.files[0]);e.target.value='';});
document.getElementById('importObjFile').addEventListener('change',e=>{handleImportFile(e.target.files[0]);openModal('povImport');e.target.value='';});
document.getElementById('importAddBtn').addEventListener('click',()=>{if(!importedObjs.length){setStat('No OBJ loaded');return;}const objData=importedObjs[importSelIdx]||importedObjs[0];const{pos,nor,col,ind,geo}=buildImportedMesh(objData);const o=makeObj(objData.name);objects.push(o);const mat=new THREE.MeshLambertMaterial({vertexColors:true,side:THREE.DoubleSide});o.mesh=new THREE.Mesh(geo,mat);o.mesh.castShadow=true;o.mesh.receiveShadow=true;sc3.add(o.mesh);o.exp={pos,nor,col,ind};selObj(o.id);renderObjs();document.getElementById('es').style.display='none';setStat(`Imported: ${objData.name} — ${Math.round(ind.length/3).toLocaleString()} tris`,'active');document.getElementById('povImport').classList.remove('open');});
document.getElementById('importReplaceBtn').addEventListener('click',()=>{const s=getSel();if(!s){setStat('Select an object first');return;}if(!importedObjs.length){setStat('No OBJ loaded');return;}const objData=importedObjs[importSelIdx]||importedObjs[0];const{pos,nor,col,ind,geo}=buildImportedMesh(objData);const mat=new THREE.MeshLambertMaterial({vertexColors:true,side:THREE.DoubleSide,emissive:new THREE.Color(0x223300)});if(s.mesh)sc3.remove(s.mesh);s.mesh=new THREE.Mesh(geo,mat);s.mesh.castShadow=true;s.mesh.receiveShadow=true;syncT(s);sc3.add(s.mesh);s.exp={pos,nor,col,ind};setStat(`Replaced: ${s.name} with ${objData.name}`,'active');document.getElementById('povImport').classList.remove('open');});

// ── ANIMATOR ──────────────────────────────────────────
const PX_PER_FRAME=14;let animFrame=0,animPlaying=false,animRAF=null,animSelectedKey=null,animLastTime=0;
function animGetTotal(){return parseInt(document.getElementById('animTotalInput').value)||60;}
function animGetFPS(){return parseInt(document.getElementById('animFpsInput').value)||24;}
function animOpen(){openModal('povAnimator');animRebuild();}
document.getElementById('ddAnimator').addEventListener('click',animOpen);
document.getElementById('animClose').addEventListener('click',()=>{document.getElementById('povAnimator').classList.remove('open');animStopPlayback();});
function animRebuild(){
  const total=animGetTotal();document.getElementById('animTotalFrames').textContent=total;const tlW=total*PX_PER_FRAME;
  const col=document.getElementById('animObjCol'),tl=document.getElementById('animTimeline');col.innerHTML='';tl.innerHTML='';
  const ruler=document.createElement('div');ruler.className='anim-ruler';ruler.style.width=tlW+'px';
  for(let f=0;f<=total;f+=Math.max(1,Math.floor(total/20))){const tick=document.createElement('div');tick.className='anim-ruler-tick';tick.style.left=(f*PX_PER_FRAME)+'px';tick.textContent=f;ruler.appendChild(tick);}
  ruler.addEventListener('click',e=>{const r=ruler.getBoundingClientRect();animSeek(Math.max(0,Math.min(total,Math.round((e.clientX-r.left)/PX_PER_FRAME))));});
  ruler.addEventListener('touchstart',e=>{e.preventDefault();const t=e.touches[0];const r=ruler.getBoundingClientRect();animSeek(Math.max(0,Math.min(total,Math.round((t.clientX-r.left)/PX_PER_FRAME))));},{passive:false});
  tl.appendChild(ruler);
  const hdrC=document.createElement('div');hdrC.className='anim-obj-row hdr';hdrC.textContent='Object';col.appendChild(hdrC);
  const hdrT=document.createElement('div');hdrT.className='anim-track-row';hdrT.style.width=tlW+'px';hdrT.style.background='#0d0d0d';tl.appendChild(hdrT);
  objects.forEach(obj=>{
    if(!obj.keyframes)obj.keyframes=[];
    const orow=document.createElement('div');orow.className='anim-obj-row';orow.textContent=obj.name;col.appendChild(orow);
    const track=document.createElement('div');track.className='anim-track-row';track.style.width=tlW+'px';track.style.background=obj.id===selectedId?'#141a0a':'#0a0a0a';
    obj.keyframes.forEach((kf,ki)=>{const d=document.createElement('div');d.className='anim-keyframe'+(animSelectedKey&&animSelectedKey.obj===obj.id&&animSelectedKey.ki===ki?' sel':'');d.style.left=(kf.frame*PX_PER_FRAME)+'px';d.title=`Frame ${kf.frame}`;d.addEventListener('click',e=>{e.stopPropagation();animSelectedKey={obj:obj.id,ki};animSeek(kf.frame);animRebuild();});track.appendChild(d);});
    track.addEventListener('click',e=>{const r=track.getBoundingClientRect();animSeek(Math.max(0,Math.min(total,Math.round((e.clientX-r.left)/PX_PER_FRAME))));});
    tl.appendChild(track);
  });
  const ph=document.createElement('div');ph.className='anim-playhead';ph.id='animPlayhead';ph.style.left=(animFrame*PX_PER_FRAME)+'px';const phh=document.createElement('div');phh.className='anim-playhead-head';ph.appendChild(phh);tl.insertBefore(ph,tl.children[1]);
  document.getElementById('animFrameNum').textContent=animFrame;
}
function animSeek(f){animFrame=f;document.getElementById('animFrameNum').textContent=f;const ph=document.getElementById('animPlayhead');if(ph)ph.style.left=(f*PX_PER_FRAME)+'px';objects.forEach(obj=>{if(!obj.keyframes||!obj.keyframes.length)return;const t=animInterp(obj.keyframes,f);if(!t)return;obj.pos={...t.pos};obj.rot={...t.rot};obj.scl={...t.scl};syncT(obj);});const sel=getSel();if(sel)updTFDisplay(sel);}
function animInterp(kfs,f){if(!kfs.length)return null;const sorted=[...kfs].sort((a,b)=>a.frame-b.frame);if(f<=sorted[0].frame)return sorted[0];if(f>=sorted[sorted.length-1].frame)return sorted[sorted.length-1];let k0=sorted[0],k1=sorted[1];for(let i=0;i<sorted.length-1;i++){if(sorted[i].frame<=f&&sorted[i+1].frame>=f){k0=sorted[i];k1=sorted[i+1];break;}}const t=(f-k0.frame)/(k1.frame-k0.frame);const et=t<.5?2*t*t:1-Math.pow(-2*t+2,2)/2;function l(a,b){return a+(b-a)*et;}return{pos:{x:l(k0.pos.x,k1.pos.x),y:l(k0.pos.y,k1.pos.y),z:l(k0.pos.z,k1.pos.z)},rot:{x:l(k0.rot.x,k1.rot.x),y:l(k0.rot.y,k1.rot.y),z:l(k0.rot.z,k1.rot.z)},scl:{x:l(k0.scl.x,k1.scl.x),y:l(k0.scl.y,k1.scl.y),z:l(k0.scl.z,k1.scl.z)}};}
document.getElementById('animAddKey').addEventListener('click',()=>{const s=getSel();if(!s){setStat('Select an object first');return;}if(!s.keyframes)s.keyframes=[];s.keyframes=s.keyframes.filter(k=>k.frame!==animFrame);s.keyframes.push({frame:animFrame,pos:{...s.pos},rot:{...s.rot},scl:{...s.scl}});s.keyframes.sort((a,b)=>a.frame-b.frame);setStat(`Keyframe: ${s.name} @ frame ${animFrame}`,'active');animRebuild();});
document.getElementById('animDelKey').addEventListener('click',()=>{if(!animSelectedKey){setStat('Tap a keyframe diamond to select it');return;}const obj=objects.find(o=>o.id===animSelectedKey.obj);if(!obj)return;obj.keyframes.splice(animSelectedKey.ki,1);animSelectedKey=null;setStat('Keyframe deleted');animRebuild();});
document.getElementById('animPlay').addEventListener('click',()=>{if(animPlaying)return;animPlaying=true;document.getElementById('animPlay').classList.add('act');animLastTime=performance.now();animTick();});
document.getElementById('animStop').addEventListener('click',animStopPlayback);
function animStopPlayback(){animPlaying=false;if(animRAF)cancelAnimationFrame(animRAF);document.getElementById('animPlay').classList.remove('act');}
function animTick(){if(!animPlaying)return;const now=performance.now();if(now-animLastTime>=1000/animGetFPS()){animLastTime+=1000/animGetFPS();animFrame++;const total=animGetTotal();if(animFrame>total)animFrame=0;animSeek(animFrame);animRebuild();}animRAF=requestAnimationFrame(animTick);}
document.getElementById('animTotalInput').addEventListener('change',()=>animRebuild());
document.getElementById('animFpsInput').addEventListener('change',()=>{});

// ── INIT ──────────────────────────────────────────────
openModal('povAbout');
buildFaceGrid();
</script>
