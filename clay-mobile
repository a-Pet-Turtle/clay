function marchingCubes(grid,N,scl,imgData,offset=0){
  const pos=[],nor=[],col=[],ind=[];let vc=0;
  const ix=(x,y,z)=>z*N*N+y*N+x;
  function vi(p1,p2,v1,v2){if(Math.abs(v1-v2)<0.00001)return[(p1[0]+p2[0])/2,(p1[1]+p2[1])/2,(p1[2]+p2[2])/2];const t=(0.5-v1)/(v2-v1);return[p1[0]+t*(p2[0]-p1[0]),p1[1]+t*(p2[1]-p1[1]),p1[2]+t*(p2[2]-p1[2])];}
  for(let x=0;x<N-1;x++)for(let y=0;y<N-1;y++)for(let z=0;z<N-1;z++){
    const v=[grid[ix(x,y,z)],grid[ix(x+1,y,z)],grid[ix(x+1,y+1,z)],grid[ix(x,y+1,z)],grid[ix(x,y,z+1)],grid[ix(x+1,y,z+1)],grid[ix(x+1,y+1,z+1)],grid[ix(x,y+1,z+1)]];
    const ox=(x-N/2)*scl,oy=(y-N/2)*scl,oz=(z-N/2)*scl;
    const cp=[[ox,oy,oz],[ox+scl,oy,oz],[ox+scl,oy+scl,oz],[ox,oy+scl,oz],[ox,oy,oz+scl],[ox+scl,oy,oz+scl],[ox+scl,oy+scl,oz+scl],[ox,oy+scl,oz+scl]];
    let ci=0;for(let i=0;i<8;i++)if(v[i]>0)ci|=(1<<i);if(ci===0||ci===255)continue;
    const em=MC_EDGE_TABLE[ci];const ep=new Array(12);
    const ED=[[0,1],[1,2],[2,3],[3,0],[4,5],[5,6],[6,7],[7,4],[0,4],[1,5],[2,6],[3,7]];
    for(let e=0;e<12;e++){if(em&(1<<e)){const[a,b]=ED[e];ep[e]=vi(cp[a],cp[b],v[a],v[b]);}}
    const tris=MC_TRI_TABLE[ci];
    for(let t=0;t<tris.length-1;t+=3){if(tris[t]===-1)break;
      const vts=[ep[tris[t]],ep[tris[t+1]],ep[tris[t+2]]];
      const ax=vts[1][0]-vts[0][0],ay=vts[1][1]-vts[0][1],az=vts[1][2]-vts[0][2];
      const bx=vts[2][0]-vts[0][0],by=vts[2][1]-vts[0][1],bz=vts[2][2]-vts[0][2];
      const nx=ay*bz-az*by,ny=az*bx-ax*bz,nz=ax*by-ay*bx;const nl=Math.sqrt(nx*nx+ny*ny+nz*nz)||1;
      function smcc(vx,vy,vz){const hs=N/2*scl;const u=(vx+hs)/(N*scl),v2=(vy+hs)/(N*scl),w=(vz+hs)/(N*scl);const nyu=1-v2;const an=Math.abs(nx/nl),ay2=Math.abs(ny/nl),az2=Math.abs(nz/nl);if(an>=ay2&&an>=az2)return nx>0?sC(imgData.right,1-w,nyu):sC(imgData.left,w,nyu);if(ay2>=an&&ay2>=az2)return ny>0?sC(imgData.top,u,w):sC(imgData.bottom,u,1-w);return nz>0?sC(imgData.front,u,nyu):sC(imgData.back,1-u,nyu);}
      const base=vc;for(const vp of vts){pos.push(vp[0],vp[1],vp[2]);nor.push(nx/nl,ny/nl,nz/nl);const c=smcc(vp[0],vp[1],vp[2]);col.push(c[0]/255,c[1]/255,c[2]/255);}
      ind.push(base,base+1,base+2);vc+=3;
    }
  }
  return{pos,nor,col,ind};
}

