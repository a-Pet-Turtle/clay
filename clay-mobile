// Drawing helpers
function gpos(e){const r=pfc.getBoundingClientRect();return[Math.floor((e.clientX-r.left)*CS/r.width),Math.floor((e.clientY-r.top)*CS/r.height)];}
function gposT(t){const r=pfc.getBoundingClientRect();return[Math.floor((t.clientX-r.left)*CS/r.width),Math.floor((t.clientY-r.top)*CS/r.height)];}
function getDrawColor(){const hex=document.getElementById('dc').value,a=+document.getElementById('da').value;if(a>=255)return hex;const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return`rgba(${r},${g},${b},${(a/255).toFixed(3)})`;}
function dbrush(ctx,x,y,erase){const sz=+document.getElementById('bsz').value,alpha=+document.getElementById('da').value;if(erase||alpha===0){ctx.globalCompositeOperation='destination-out';ctx.beginPath();ctx.arc(x,y,sz/2,0,Math.PI*2);ctx.fillStyle='rgba(0,0,0,1)';ctx.fill();ctx.globalCompositeOperation='source-over';}else{ctx.globalCompositeOperation='source-over';ctx.beginPath();ctx.arc(x,y,sz/2,0,Math.PI*2);ctx.fillStyle=getDrawColor();ctx.fill();}}
function h2r(h){return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)};}
function doFill(ctx,sx,sy,hex){const img=ctx.getImageData(0,0,CS,CS),dd=img.data;const ti=(sy*CS+sx)*4,tr=dd[ti],tg=dd[ti+1],tb=dd[ti+2],ta=dd[ti+3];const fc2=h2r(hex);if(tr===fc2.r&&tg===fc2.g&&tb===fc2.b&&ta===255)return;const stk=[[sx,sy]];while(stk.length){const[cx,cy]=stk.pop();if(cx<0||cx>=CS||cy<0||cy>=CS)continue;const i=(cy*CS+cx)*4;if(dd[i]!==tr||dd[i+1]!==tg||dd[i+2]!==tb||dd[i+3]!==ta)continue;dd[i]=fc2.r;dd[i+1]=fc2.g;dd[i+2]=fc2.b;dd[i+3]=255;stk.push([cx+1,cy],[cx-1,cy],[cx,cy+1],[cx,cy-1]);}ctx.putImageData(img,0,0);}
function doShape(ctx,sx,sy,ex,ey,tool,filled){const a=+document.getElementById('da').value;const useErase=a===0;if(useErase){ctx.globalCompositeOperation='destination-out';ctx.strokeStyle=ctx.fillStyle='rgba(0,0,0,1)';}else{ctx.globalCompositeOperation='source-over';ctx.strokeStyle=ctx.fillStyle=getDrawColor();}ctx.lineWidth=+document.getElementById('bsz').value;ctx.lineCap='round';if(tool==='line'){ctx.beginPath();ctx.moveTo(sx,sy);ctx.lineTo(ex,ey);ctx.stroke();}else if(tool==='rect'){if(filled)ctx.fillRect(sx,sy,ex-sx,ey-sy);else ctx.strokeRect(sx+.5,sy+.5,ex-sx,ey-sy);}else if(tool==='oval'){const cx=(sx+ex)/2,cy=(sy+ey)/2,rx=Math.abs(ex-sx)/2,ry=Math.abs(ey-sy)/2;ctx.beginPath();ctx.ellipse(cx,cy,Math.max(1,rx),Math.max(1,ry),0,0,Math.PI*2);if(filled)ctx.fill();else ctx.stroke();}else if(tool==='disk'){const cx=(sx+ex)/2,cy=(sy+ey)/2,r=Math.max(1,Math.hypot(ex-sx,ey-sy)/2);ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);if(filled)ctx.fill();else ctx.stroke();}else if(tool==='tri'){const mx=(sx+ex)/2;ctx.beginPath();ctx.moveTo(mx,sy);ctx.lineTo(ex,ey);ctx.lineTo(sx,ey);ctx.closePath();if(filled)ctx.fill();else ctx.stroke();}ctx.globalCompositeOperation='source-over';}

// Touch drawing on face editor canvas
let drawTouchId=null;
pfc.addEventListener('touchstart',e=>{
  e.preventDefault();if(!getSel())return;
  const t=e.changedTouches[0];drawTouchId=t.identifier;
  const s=getSel();const ctx=s.fc[curFace].getContext('2d');
  let[x,y]=gposT(t);[x,y]=applySnap(x,y);
  pushU();drawing=true;lastX=x;lastY=y;
  if(curTool==='fill'){doFill(ctx,x,y,document.getElementById('dc').value);drawPop();return;}
  if(curTool==='brush'||curTool==='eraser'){dbrush(ctx,x,y,curTool==='eraser');drawPop();}
  if(['line','rect','oval','disk','tri'].includes(curTool)){snapData=ctx.getImageData(0,0,CS,CS);shpStart=[x,y];}
},{passive:false});
pfc.addEventListener('touchmove',e=>{
  e.preventDefault();if(!drawing)return;const s=getSel();if(!s)return;
  const t=Array.from(e.changedTouches).find(t=>t.identifier===drawTouchId);if(!t)return;
  const ctx=s.fc[curFace].getContext('2d');let[x,y]=gposT(t);[x,y]=applySnap(x,y);
  if(curTool==='brush'||curTool==='eraser'){const er=curTool==='eraser',alpha=+document.getElementById('da').value,useErase=er||alpha===0;ctx.globalCompositeOperation=useErase?'destination-out':'source-over';ctx.strokeStyle=useErase?'rgba(0,0,0,1)':getDrawColor();ctx.lineWidth=+document.getElementById('bsz').value;ctx.lineCap='round';ctx.lineJoin='round';ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(x,y);ctx.stroke();dbrush(ctx,x,y,useErase);ctx.globalCompositeOperation='source-over';lastX=x;lastY=y;drawPop();}
  else if(shpStart&&snapData){ctx.putImageData(snapData,0,0);doShape(ctx,shpStart[0],shpStart[1],x,y,curTool,fillShapes);drawPop();}
},{passive:false});
pfc.addEventListener('touchend',e=>{if(drawing){drawing=false;snapData=null;drawTouchId=null;refreshThumbs();}},{passive:false});

// Mouse drawing
pfc.addEventListener('mousedown',e=>{
  e.preventDefault();const s=getSel();if(!s)return;
  const ctx=s.fc[curFace].getContext('2d');let[x,y]=gpos(e);[x,y]=applySnap(x,y);
  pushU();drawing=true;lastX=x;lastY=y;
  if(curTool==='fill'){doFill(ctx,x,y,document.getElementById('dc').value);drawPop();return;}
  if(curTool==='brush'||curTool==='eraser'){dbrush(ctx,x,y,curTool==='eraser');drawPop();}
  if(['line','rect','oval','disk','tri'].includes(curTool)){snapData=ctx.getImageData(0,0,CS,CS);shpStart=[x,y];}
});
window.addEventListener('mousemove',e2=>{
  if(!drawing)return;const s=getSel();if(!s)return;
  const ctx=s.fc[curFace].getContext('2d');let[x,y]=gpos(e2);[x,y]=applySnap(x,y);
  if(curTool==='brush'||curTool==='eraser'){const er=curTool==='eraser',alpha=+document.getElementById('da').value,useErase=er||alpha===0;ctx.globalCompositeOperation=useErase?'destination-out':'source-over';ctx.strokeStyle=useErase?'rgba(0,0,0,1)':getDrawColor();ctx.lineWidth=+document.getElementById('bsz').value;ctx.lineCap='round';ctx.lineJoin='round';ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(x,y);ctx.stroke();dbrush(ctx,x,y,useErase);ctx.globalCompositeOperation='source-over';lastX=x;lastY=y;drawPop();}
  else if(shpStart&&snapData){ctx.putImageData(snapData,0,0);doShape(ctx,shpStart[0],shpStart[1],x,y,curTool,fillShapes);drawPop();}
