const TF_STEPS={px:0.1,py:0.1,pz:0.1,rx:5,ry:5,rz:5,sx:0.1,sy:0.1,sz:0.1};
const TF_MIN={sx:0.01,sy:0.01,sz:0.01};
document.getElementById('ddTransform').addEventListener('click',()=>{const s=getSel();if(s)updTFDisplay(s);openModal('povTransform');});
document.getElementById('tfClose').addEventListener('click',()=>document.getElementById('povTransform').classList.remove('open'));
