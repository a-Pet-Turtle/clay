function updCam(){cam.position.set(ct.x+sph.r*Math.sin(sph.p)*Math.sin(sph.t),ct.y+sph.r*Math.cos(sph.p),ct.z+sph.r*Math.sin(sph.p)*Math.cos(sph.t));cam.lookAt(ct);}
