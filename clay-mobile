document.querySelectorAll('.tf-btn-sm').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const o=getSel();if(!o)return;
    pushTransUndo();
    const field=btn.dataset.tf,dir=+btn.dataset.dir,step=TF_STEPS[field]||0.1;
    const axis=field[1];
    if(field[0]==='p')o.pos[axis]=Math.round((o.pos[axis]+dir*step)*1000)/1000;
    else if(field[0]==='r')o.rot[axis]=Math.round(o.rot[axis]+dir*step);
    else if(field[0]==='s'){let v=Math.max(TF_MIN[field]||0.01,Math.round((o.scl[axis]+dir*step)*100)/100);if(uniformScale)o.scl={x:v,y:v,z:v};else o.scl[axis]=v;}
    syncT(o);updTFDisplay(o);
  });
});
document.getElementById('uniformScaleBtn').addEventListener('click',function(){uniformScale=!uniformScale;this.textContent=uniformScale?'🔗 Uniform ON':'🔗 Uniform scale';this.classList.toggle('act',uniformScale);});

function getTransState(o){return JSON.stringify({pos:{...o.pos},rot:{...o.rot},scl:{...o.scl}});}
function applyTransState(o,state){const s=JSON.parse(state);o.pos={...s.pos};o.rot={...s.rot};o.scl={...s.scl};syncT(o);updTFDisplay(o);}
function pushTransUndo(){const o=getSel();if(!o)return;if(!o.transUndo)o.transUndo=[];if(!o.transRedo)o.transRedo=[];o.transUndo.push(getTransState(o));if(o.transUndo.length>50)o.transUndo.shift();o.transRedo=[];}
document.getElementById('undoTransBtn').addEventListener('click',()=>{const o=getSel();if(!o||!o.transUndo||!o.transUndo.length)return;if(!o.transRedo)o.transRedo=[];o.transRedo.push(getTransState(o));applyTransState(o,o.transUndo.pop());setStat('Transform undone');});
document.getElementById('redoTransBtn').addEventListener('click',()=>{const o=getSel();if(!o||!o.transRedo||!o.transRedo.length)return;if(!o.transUndo)o.transUndo=[];o.transUndo.push(getTransState(o));applyTransState(o,o.transRedo.pop());setStat('Transform redone');});

