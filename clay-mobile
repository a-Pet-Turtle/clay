// ── SAVE / LOAD ───────────────────────────────────────
document.getElementById('ddSave').addEventListener('click',()=>{
  const data={version:2,objects:[]};
  objects.forEach(o=>{const fd={};FACES.forEach(f=>{fd[f]=o.fc[f].toDataURL('image/png');});data.objects.push({id:o.id,name:o.name,pos:{...o.pos},rot:{...o.rot},scl:{...o.scl},keyframes:o.keyframes||[],faceData:fd});});
  const bl=new Blob([JSON.stringify(data)],{type:'application/octet-stream'});const a=document.createElement('a');a.href=URL.createObjectURL(bl);a.download='scene.cly';a.click();setStat('Saved scene.cly','active');
