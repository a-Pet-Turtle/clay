<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ── CORE STATE ────────────────────────────────────────
const FACES=['front','back','left','right','top','bottom'];
const CS=256, D2R=Math.PI/180;
let objects=[], selectedId=null, curFace='front', curTool='brush', fillShapes=true;
let drawing=false, lastX=0, lastY=0, shpStart=null, snapData=null;
let uniformScale=false, wireframe=false, meshMode='flat';
let snapGrid=0; const snapSizes=[0,4,8,16,32]; let snapIdx=0;
let onionOn=false;
const ONION_PAIRS={front:'back',back:'front',left:'right',right:'left',top:'bottom',bottom:'top'};

function makeObj(name){
  const id='o'+Date.now()+Math.random().toString(36).slice(2,5);
  const fc={};
  FACES.forEach(f=>{const c=document.createElement('canvas');c.width=CS;c.height=CS;fc[f]=c;});
  return{id,name,fc,us:Object.fromEntries(FACES.map(f=>[f,[]])),mesh:null,exp:null,
    pos:{x:0,y:0,z:0},rot:{x:0,y:0,z:0},scl:{x:1,y:1,z:1},keyframes:[]};
}
function getSel(){return objects.find(o=>o.id===selectedId)||null;}

// ── THREE.JS SCENE ────────────────────────────────────
const cv3=document.getElementById('c3');
const ren=new THREE.WebGLRenderer({canvas:cv3,antialias:true});
ren.setPixelRatio(devicePixelRatio); ren.setClearColor(0x080808);
ren.shadowMap.enabled=true; ren.shadowMap.type=THREE.PCFSoftShadowMap||3;
const sc3=new THREE.Scene();
const cam=new THREE.PerspectiveCamera(50,1,.1,1000);
cam.position.set(3,2.5,4); cam.lookAt(0,0,0);
const ambLight=new THREE.AmbientLight(0xffffff,.4); sc3.add(ambLight);
const dl=new THREE.DirectionalLight(0xffffff,.9);
dl.position.set(4,6,5); dl.castShadow=true;
dl.shadow.mapSize.width=2048; dl.shadow.mapSize.height=2048;
dl.shadow.camera.near=0.1; dl.shadow.camera.far=50;
dl.shadow.camera.left=-6; dl.shadow.camera.right=6;
dl.shadow.camera.top=6; dl.shadow.camera.bottom=-6;
dl.shadow.bias=-0.001; sc3.add(dl);
const dl2=new THREE.DirectionalLight(0x7799dd,.2); dl2.position.set(-3,-2,-4); sc3.add(dl2);
sc3.add(new THREE.GridHelper(6,24,0x1e1e1e,0x1a1a1a));
const groundGeo=new THREE.PlaneGeometry(20,20);
const groundMat=new THREE.ShadowMaterial({opacity:0.35});
const ground=new THREE.Mesh(groundGeo,groundMat);
ground.rotation.x=-Math.PI/2; ground.position.y=-1; ground.receiveShadow=true; sc3.add(ground);

function rzz(){const v=document.querySelector('.vp');ren.setSize(v.clientWidth,v.clientHeight);cam.aspect=v.clientWidth/v.clientHeight;cam.updateProjectionMatrix();}
rzz(); window.addEventListener('resize',rzz);

// ── TOUCH/MOUSE CONTROLS ──────────────────────────────
let sph={t:.6,p:1.1,r:5}, ct=new THREE.Vector3();
let touches2={}, lastPinchDist=null;
cv3.addEventListener('touchstart',e=>{e.preventDefault();Array.from(e.changedTouches).forEach(t=>touches2[t.identifier]={x:t.clientX,y:t.clientY});},{passive:false});
cv3.addEventListener('touchmove',e=>{
  e.preventDefault();
  if(e.touches.length===1){
    const t=e.touches[0],prev=touches2[t.identifier];
    if(prev){const dx=t.clientX-prev.x,dy=t.clientY-prev.y;sph.t-=dx*.012;sph.p=Math.max(.05,Math.min(Math.PI-.05,sph.p-dy*.012));touches2[t.identifier]={x:t.clientX,y:t.clientY};}
  } else if(e.touches.length===2){
    const a=e.touches[0],b=e.touches[1];
    const dist=Math.hypot(a.clientX-b.clientX,a.clientY-b.clientY);
    if(lastPinchDist!==null){sph.r=Math.max(.5,Math.min(30,sph.r+(lastPinchDist-dist)*.02));}
    lastPinchDist=dist;
    const cx=(a.clientX+b.clientX)/2,cy=(a.clientY+b.clientY)/2;
    const pA=touches2[a.identifier],pB=touches2[b.identifier];
    if(pA&&pB){const pdx=cx-(pA.x+pB.x)/2,pdy=cy-(pA.y+pB.y)/2;const fw=new THREE.Vector3().subVectors(cam.position,ct).normalize();const r=new THREE.Vector3().crossVectors(new THREE.Vector3(0,1,0),fw).normalize();ct.addScaledVector(r,-pdx*.007);ct.y+=pdy*.007;}
    touches2[a.identifier]={x:a.clientX,y:a.clientY};touches2[b.identifier]={x:b.clientX,y:b.clientY};
  }
},{passive:false});
cv3.addEventListener('touchend',e=>{Array.from(e.changedTouches).forEach(t=>delete touches2[t.identifier]);if(e.touches.length<2)lastPinchDist=null;},{passive:false});
let dg=false,pn=false,pmx=0,pmy=0;
cv3.addEventListener('mousedown',e=>{if(e.button===0)dg=true;if(e.button===2)pn=true;pmx=e.clientX;pmy=e.clientY;});
cv3.addEventListener('contextmenu',e=>e.preventDefault());
window.addEventListener('mouseup',()=>{dg=false;pn=false;});
window.addEventListener('mousemove',e=>{const dx=e.clientX-pmx,dy=e.clientY-pmy;if(dg){sph.t-=dx*.01;sph.p=Math.max(.05,Math.min(Math.PI-.05,sph.p-dy*.01));}if(pn){const fw=new THREE.Vector3().subVectors(cam.position,ct).normalize();const r=new THREE.Vector3().crossVectors(new THREE.Vector3(0,1,0),fw).normalize();ct.addScaledVector(r,dx*.006);ct.y-=dy*.006;}pmx=e.clientX;pmy=e.clientY;});
cv3.addEventListener('wheel',e=>{sph.r=Math.max(.5,Math.min(30,sph.r+e.deltaY*.006));});
