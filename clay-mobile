const pfc=document.getElementById('pfc'),pctx=pfc.getContext('2d');
function drawPop(){
  const s=getSel();if(!s)return;
  const sq=12;
  for(let y=0;y<CS/sq;y++)for(let x=0;x<CS/sq;x++){pctx.fillStyle=(x+y)%2?'#333':'#222';pctx.fillRect(x*sq,y*sq,sq,sq);}
  pctx.drawImage(s.fc[curFace],0,0);
  if(snapGrid>0){pctx.save();pctx.strokeStyle='rgba(200,255,0,0.15)';pctx.lineWidth=1;pctx.beginPath();for(let gx=snapGrid;gx<CS;gx+=snapGrid){pctx.moveTo(Math.floor(gx)+.5,0);pctx.lineTo(Math.floor(gx)+.5,CS);}for(let gy=snapGrid;gy<CS;gy+=snapGrid){pctx.moveTo(0,Math.floor(gy)+.5);pctx.lineTo(CS,Math.floor(gy)+.5);}pctx.stroke();pctx.restore();}
  if(onionOn){const opp=ONION_PAIRS[curFace];if(opp&&s.fc[opp]){pctx.save();pctx.globalAlpha=0.28;pctx.translate(CS,0);pctx.scale(-1,1);pctx.drawImage(s.fc[opp],0,0);pctx.restore();}}
}
function openPop(face){
  const s=getSel();if(!s)return;
  curFace=face;
  document.getElementById('ptitle').textContent=face.charAt(0).toUpperCase()+face.slice(1)+' Face';
  document.querySelectorAll('#fnav button').forEach(b=>b.classList.toggle('act',b.dataset.f===face));
  drawPop();openModal('povEditor');refreshThumbs();
  setTimeout(()=>{const wrap=pfc.parentElement;const sz=Math.min(wrap.clientWidth-16,wrap.clientHeight-24,CS);pfc.style.width=sz+'px';pfc.style.height=sz+'px';},50);
}
