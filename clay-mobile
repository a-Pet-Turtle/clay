document.getElementById('ddLoad').addEventListener('click',()=>document.getElementById('loadInput').click());
document.getElementById('loadInput').addEventListener('change',async e=>{
  const file=e.target.files[0];if(!file)return;
  const text=await file.text();let data;try{data=JSON.parse(text);}catch(err){setStat('Error: invalid .cly file');return;}
  objects.forEach(o=>{if(o.mesh)sc3.remove(o.mesh);});objects=[];selectedId=null;
  const lf=(du)=>new Promise(res=>{const img=new Image();img.onload=()=>{const c=document.createElement('canvas');c.width=CS;c.height=CS;c.getContext('2d').drawImage(img,0,0,CS,CS);res(c);};img.src=du;});
  for(const od of data.objects){const o=makeObj(od.name);o.id=od.id;o.pos={...od.pos};o.rot={...od.rot};o.scl={...(od.scl||{x:1,y:1,z:1})};o.keyframes=od.keyframes||[];for(const f of FACES){if(od.faceData&&od.faceData[f])o.fc[f]=await lf(od.faceData[f]);}objects.push(o);}
  renderObjs();buildFaceGrid();document.getElementById('es').style.display=objects.length?'none':'flex';
  setStat('Loaded '+file.name,'active');e.target.value='';
  if(objects.length){selObj(objects[0].id);await new Promise(r=>setTimeout(r,100));for(const o of objects)await buildObj(o);}
});

