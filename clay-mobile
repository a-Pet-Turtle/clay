const LAYOUT=[null,'top',null,'left','front','right',null,'bottom',null,null,'back',null];
function buildFaceGrid(){
  const g=document.getElementById('faceGrid');g.innerHTML='';
  const sel=getSel();
  document.getElementById('noObjMsg').style.display=sel?'none':'block';
  LAYOUT.forEach(face=>{
    const d=document.createElement('div');
    if(!face){d.style.background='transparent';g.appendChild(d);return;}
    d.className='ftb'+(face===curFace?' af':'');d.dataset.f=face;
    const mc=document.createElement('canvas');mc.width=CS;mc.height=CS;
    if(sel)drawThumb(mc.getContext('2d'),sel.fc[face]);
    d.appendChild(mc);
    const sp=document.createElement('span');sp.textContent=face;d.appendChild(sp);
    d.addEventListener('click',()=>{if(sel)openPop(face);else{document.getElementById('povFaces').classList.remove('open');openModal('povObjects');setStat('Select an object first');}});
    g.appendChild(d);
  });
}
function drawThumb(ctx,fc){for(let y=0;y<16;y++)for(let x=0;x<16;x++){ctx.fillStyle=(x+y)%2?'#2a2a2a':'#1a1a1a';ctx.fillRect(x*16,y*16,16,16);}ctx.drawImage(fc,0,0);}
function refreshThumbs(){const sel=getSel();document.querySelectorAll('.ftb').forEach(b=>{const f=b.dataset.f;if(!f)return;const mc=b.querySelector('canvas');if(!mc)return;if(sel)drawThumb(mc.getContext('2d'),sel.fc[f]);b.classList.toggle('af',f===curFace);});}
